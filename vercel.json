{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build:web",
  "devCommand": "pnpm dev:web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/apps/web/api/:path*"
    }
  ],
  "functions": {
    "apps/web/api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  }
}
