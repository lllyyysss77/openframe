{
  "name": "openframe-root",
  "private": true,
  "packageManager": "pnpm@9.12.2",
  "version": "0.0.10",
  "scripts": {
    "dev": "pnpm --filter openframe dev",
    "build": "pnpm --filter openframe build",
    "build:current": "pnpm --filter openframe build:current",
    "build:mac": "pnpm --filter openframe build:mac",
    "build:win": "pnpm --filter openframe build:win",
    "build:linux": "pnpm --filter openframe build:linux",
    "lint": "pnpm -r lint",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "pnpm --filter openframe db:generate",
    "db:migrate": "pnpm --filter openframe db:migrate",
    "release": "bumpp --commit --tag --push"
  },
  "devDependencies": {
    "bumpp": "^10.2.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron"
    ]
  }
}
