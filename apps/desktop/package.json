{
  "name": "openframe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc && electron-builder --mac zip --x64 --arm64 && electron-builder --win --x64 && electron-builder --linux --x64",
    "build:current": "vite build && tsc && electron-builder",
    "build:mac": "vite build && tsc && electron-builder --mac",
    "build:mac:dmg": "vite build && tsc && electron-builder --mac dmg",
    "build:win": "vite build && tsc && electron-builder --win",
    "build:linux": "vite build && tsc && electron-builder --linux",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@openframe/db": "workspace:*",
    "@openframe/providers": "workspace:*",
    "@openframe/shared": "workspace:*",
    "@tanstack/db": "^0.5.28",
    "@tanstack/react-db": "^0.1.72",
    "@tanstack/react-router": "^1.162.2",
    "@tiptap/core": "^3.20.0",
    "@tiptap/markdown": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "ai": "^6.0.97",
    "better-sqlite3": "^12.6.2",
    "cytoscape": "^3.33.1",
    "driver.js": "^1.4.0",
    "drizzle-orm": "^0.45.1",
    "electron-store": "^11.0.2",
    "i18next": "^25.8.13",
    "lucide-react": "^0.575.0",
    "p-queue": "^9.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.4",
    "react-player": "^3.4.0",
    "sqlite-vec": "0.1.7-alpha.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/router-plugin": "^1.162.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.9",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}
